# Public Supabase credentials — safe to ship in the browser bundle.
# These are the ONLY env vars the running app needs.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# NOTE: SUPABASE_SERVICE_ROLE_KEY is used ONCE locally to seed the admin
# (see README — "First-deploy runbook"). It is never added to .env,
# never set in Vercel, and never deployed anywhere.
